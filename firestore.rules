rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function getUserDoc() {
      return get(/databases/$(database)/documents/students/$(uid())).data;
    }

    function getFacultyDoc() {
      return get(/databases/$(database)/documents/faculty/$(uid())).data;
    }

    function isStudent() {
      return isAuth() && exists(/databases/$(database)/documents/students/$(uid()));
    }

    function isFaculty() {
      return isAuth() && exists(/databases/$(database)/documents/faculty/$(uid()));
    }

    function isSuperAdmin() {
      return (isAuth() && request.auth.token.email == 'gandhiatharv565@gmail.com') ||
             (isAuth() && exists(/databases/$(database)/documents/faculty/$(uid())) && getFacultyDoc().role == 'ADMIN');
    }

    function isDean() {
      return isAuth() && exists(/databases/$(database)/documents/faculty/$(uid())) && getFacultyDoc().role == 'DEAN';
    }

    function isHOD() {
      return isAuth() && exists(/databases/$(database)/documents/faculty/$(uid())) && getFacultyDoc().role == 'HOD';
    }

    function isSectionHead() {
      return isAuth() && exists(/databases/$(database)/documents/faculty/$(uid())) && getFacultyDoc().role == 'SECTION_HEAD';
    }

    function isHODForDept(dept) {
      return isHOD() && getFacultyDoc().department == dept;
    }

    // Global Admin Override: Super admins get full read/write access to everything
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // ── Students Collection ────────────────────────────────────────────────────
    match /students/{studentId} {
      allow read: if isAuth() && (
        uid() == studentId || 
        isFaculty() || 
        isHODForDept(resource.data.department) || 
        isDean() || 
        isSuperAdmin()
      );
      allow create: if (isAuth() && uid() == studentId && request.resource.data.role == 'STUDENT') || isSuperAdmin();
      allow update: if isAuth() && (
        (uid() == studentId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'phone', 'interests', 'skills', 'careerGoal', 'updatedAt'])) ||
        (isFaculty() && resource.data.mentorId == uid()) || 
        isHODForDept(resource.data.department) ||
        isDean() ||
        isSuperAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    // ── Faculty Collection ─────────────────────────────────────────────────────
    match /faculty/{facultyId} {
      allow read: if isAuth();
      allow create: if isAuth() && uid() == facultyId && (
        (request.resource.data.role == 'FACULTY' && request.resource.data.status == 'pending' && request.resource.data.isApproved == false) ||
        (request.resource.data.role in ['HOD', 'DEAN', 'SECTION_HEAD', 'ADMIN'] && request.resource.data.status == 'approved' && request.resource.data.isApproved == true)
      ) || isSuperAdmin();
      allow update: if isAuth() && (
        (uid() == facultyId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'phone', 'designation', 'updatedAt'])) ||
        isDean() ||
        isSuperAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    // ── Meetings Collection ────────────────────────────────────────────────────
    match /meetings/{meetingId} {
      function canAccessMeeting() {
        return isAuth() && (
          resource.data.studentId == uid() ||
          resource.data.mentorId  == uid() ||
          (isStudent() && resource.data.studentId == 'ALL' && resource.data.mentorId == getUserDoc().mentorId) ||
          isDean() || isSuperAdmin()
        );
      }

      allow read: if canAccessMeeting();
      allow create: if (isStudent() && request.resource.data.studentId == uid() && request.resource.data.status == 'REQUESTED') ||
                       (isFaculty() && request.resource.data.mentorId == uid());
      allow update: if isAuth() && (
        (resource.data.studentId == uid() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']) && request.resource.data.status == 'CANCELLED') ||
        resource.data.mentorId == uid()
      );
      allow delete: if isSuperAdmin();
      
      // Lock down signaling to only people allowed to access the meeting
      match /signaling/{docId} {
        allow read, write: if get(/databases/$(database)/documents/meetings/$(meetingId)).data.studentId == uid() ||
                              get(/databases/$(database)/documents/meetings/$(meetingId)).data.mentorId == uid() ||
                              (isStudent() && get(/databases/$(database)/documents/meetings/$(meetingId)).data.studentId == 'ALL' && get(/databases/$(database)/documents/meetings/$(meetingId)).data.mentorId == getUserDoc().mentorId);
      }
    }

    // ── Issues Collection ──────────────────────────────────────────────────────
    match /issues/{issueId} {
      allow read: if isAuth() && (
        resource.data.studentId  == uid() ||
        resource.data.mentorId   == uid() ||
        isHODForDept(resource.data.department) ||
        (isSectionHead() && resource.data.escalationLevel == getFacultyDoc().department) || // Section Head uses department field for their section name
        isDean() || isSuperAdmin()
      );
      allow create: if (isStudent() && request.resource.data.studentId == uid() && request.resource.data.status == 'OPEN') ||
                       (isFaculty() && request.resource.data.mentorId == uid() && request.resource.data.status == 'OPEN');
      allow update: if isAuth() && (
        resource.data.mentorId  == uid() ||
        isHODForDept(resource.data.department) ||
        (isSectionHead() && resource.data.escalationLevel == getFacultyDoc().department) ||
        isDean() || isSuperAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    // ── Action Items (Tasks) Collection ───────────────────────────────────────
    match /action_items/{itemId} {
      allow read: if isAuth() && (
        resource.data.studentId == uid() ||
        resource.data.mentorId  == uid()
      );
      allow create: if isFaculty() && request.resource.data.mentorId == uid();
      allow update: if isAuth() && (
        resource.data.studentId == uid() ||
        resource.data.mentorId  == uid()
      );
      allow delete: if isFaculty() && resource.data.mentorId == uid();
    }

    // ── Notifications Collection ───────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read:   if isAuth() && resource.data.userId == uid();
      allow create: if isAuth() &&
        request.resource.data.keys().hasAll(['userId', 'type', 'title', 'message', 'isRead', 'createdAt']) &&
        request.resource.data.isRead == false;
      allow update: if isAuth() && resource.data.userId == uid();
      allow delete: if isAuth() && resource.data.userId == uid();
    }

    // ── Departments Collection ─────────────────────────────────────────────────
    match /departments/{deptId} {
      allow read:   if true;
      allow write:  if isSuperAdmin();
    }

    // ── Classes Collection ─────────────────────────────────────────────────────
    match /classes/{classId} {
      allow read:   if true;
      allow write:  if isSuperAdmin();
    }

    // ── Settings Collection ────────────────────────────────────────────────────
    match /settings/{docId} {
      allow read:   if isAuth();
      allow write:  if isSuperAdmin();
    }

    // ── Booklets Collection ────────────────────────────────────────────────────
    match /booklets/{studentId} {
      allow read: if isAuth() && (
        uid() == studentId ||
        (isFaculty() && get(/databases/$(database)/documents/students/$(studentId)).data.mentorId == uid()) ||
        isHODForDept(get(/databases/$(database)/documents/students/$(studentId)).data.department) ||
        isDean() ||
        isSuperAdmin()
      );
      
      allow create: if isAuth() && (
        uid() == studentId ||
        isSuperAdmin()
      );
      
      allow update: if isAuth() && (
        uid() == studentId ||
        (isFaculty() && get(/databases/$(database)/documents/students/$(studentId)).data.mentorId == uid()) ||
        isSuperAdmin()
      );
      
      allow delete: if isSuperAdmin();
    }
  }
}
